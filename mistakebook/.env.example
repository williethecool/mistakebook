# ─────────────────────────────────────────────────────────────────────────────
# MistakeBook — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-nextauth-secret-here

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database (Vercel Postgres / Neon) ─────────────────────────────────────────
# Automatically set when you add Vercel Postgres to your project.
# For local dev, use a Neon or Supabase Postgres connection string.
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# ── Vercel Blob Storage (optional default storage) ───────────────────────────
# Automatically set when you add Vercel Blob to your project.
BLOB_READ_WRITE_TOKEN=

# ── AI API (can also be configured per-user in Settings) ─────────────────────
# These act as fallback defaults if user hasn't set their own key.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
